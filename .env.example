# Database - External PostgreSQL installation
DATABASE_URL=postgresql://postgres:password@localhost:5432/data_lens

# Redis - External Redis installation  
REDIS_URL=redis://localhost:6379

# LLM Providers
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Development
DEBUG=true
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# External Services Configuration
# Update these URLs to match your external PostgreSQL and Redis installations
# Examples:
# DATABASE_URL=postgresql://username:password@your-postgres-host:5432/database_name
# REDIS_URL=redis://your-redis-host:6379/0